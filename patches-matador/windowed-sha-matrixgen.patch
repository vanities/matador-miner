+// Forward declaration: the midstate fast path falls back to the original
+// full-schedule from_oracle (defined below) for retry / rejection cases.
+__device__ Element d_from_oracle(const uint8_t* seed, uint32_t index);
+
+// ---------------------------------------------------------------------------
+// Fast from_oracle via per-seed SHA-256 midstate (ported from matmul_kernel.cu).
+//
+// The seed occupies SHA words w[0..7] and is CONSTANT across every element of a
+// matrix, so compression rounds 0-7 (which only consume w[0..7]) are identical
+// for all 262144 elements. We compute that midstate (the 8 seed words + the 8
+// working-state words after round 7) ONCE per seed, then resume each element's
+// hash at round 8. This is byte-identical to d_from_oracle above: same seed
+// byte order (seed[31-i]), same LE index at bytes 32..35, same single-block
+// 36-byte message, same little-endian candidate from state[0], same retry and
+// "oracle-fallback" handling (which fall back to the original full-schedule
+// helper d_from_oracle, exercised only when the midstate candidate is rejected).
+// ---------------------------------------------------------------------------
+
+__device__ __forceinline__ uint32_t d_ms_ch(uint32_t x, uint32_t y, uint32_t z)
+{
+    return (x & y) ^ (~x & z);
+}
+__device__ __forceinline__ uint32_t d_ms_maj(uint32_t x, uint32_t y, uint32_t z)
+{
+    return (x & y) ^ (x & z) ^ (y & z);
+}
+__device__ __forceinline__ uint32_t d_ms_ep0(uint32_t x)
+{
+    return d_rotr(x, 2) ^ d_rotr(x, 13) ^ d_rotr(x, 22);
+}
+__device__ __forceinline__ uint32_t d_ms_ep1(uint32_t x)
+{
+    return d_rotr(x, 6) ^ d_rotr(x, 11) ^ d_rotr(x, 25);
+}
+__device__ __forceinline__ uint32_t d_ms_sig0(uint32_t x)
+{
+    return d_rotr(x, 7) ^ d_rotr(x, 18) ^ (x >> 3);
+}
+__device__ __forceinline__ uint32_t d_ms_sig1(uint32_t x)
+{
+    return d_rotr(x, 17) ^ d_rotr(x, 19) ^ (x >> 10);
+}
+__device__ __forceinline__ uint32_t d_ms_bswap32(uint32_t x)
+{
+    return ((x & 0x000000ffU) << 24U) | ((x & 0x0000ff00U) << 8U) |
+           ((x & 0x00ff0000U) >> 8U) | ((x & 0xff000000U) >> 24U);
+}
+
+// Compute the 16-word midstate for a seed: words [0..7] are the 8 big-endian
+// seed words (w[0..7]); words [8..15] are the working state (a..h) after the
+// first 8 compression rounds. d_K must already be initialised on device.
+__device__ void d_seed_midstate(const uint8_t* seed, uint32_t midstate[16])
+{
+    // Same byte order as d_from_oracle: SHA block bytes 0..31 = seed[31-i].
+    uint32_t w[8];
+    #pragma unroll
+    for (int i = 0; i < 8; ++i) {
+        const int base = i * 4;
+        w[i] = (uint32_t(seed[31 - base]) << 24) |
+               (uint32_t(seed[31 - base - 1]) << 16) |
+               (uint32_t(seed[31 - base - 2]) << 8) |
+               uint32_t(seed[31 - base - 3]);
+    }
+    uint32_t a = 0x6a09e667U, b = 0xbb67ae85U, c = 0x3c6ef372U, d = 0xa54ff53aU;
+    uint32_t e = 0x510e527fU, f = 0x9b05688cU, g = 0x1f83d9abU, h = 0x5be0cd19U;
+    #pragma unroll
+    for (int t = 0; t < 8; ++t) {
+        const uint32_t t1 = h + d_ms_ep1(e) + d_ms_ch(e, f, g) + d_K[t] + w[t];
+        const uint32_t t2 = d_ms_ep0(a) + d_ms_maj(a, b, c);
+        h = g; g = f; f = e; e = d + t1;
+        d = c; c = b; b = a; a = t1 + t2;
+    }
+    midstate[0] = w[0]; midstate[1] = w[1]; midstate[2] = w[2]; midstate[3] = w[3];
+    midstate[4] = w[4]; midstate[5] = w[5]; midstate[6] = w[6]; midstate[7] = w[7];
+    midstate[8] = a; midstate[9] = b; midstate[10] = c; midstate[11] = d;
+    midstate[12] = e; midstate[13] = f; midstate[14] = g; midstate[15] = h;
+}
+
+// Resume the single-block SHA at round 8 for a 36-byte (retry-0) message:
+// bytes 32..35 = LE index, byte 36 = 0x80, length word = 36*8. Returns the
+// little-endian candidate masked with MODULUS, matching d_from_oracle exactly.
+__device__ __forceinline__ uint32_t d_candidate_from_midstate_local(const uint32_t* mb, uint32_t index)
+{
+    uint32_t w[16];
+    w[0] = mb[0]; w[1] = mb[1]; w[2] = mb[2]; w[3] = mb[3];
+    w[4] = mb[4]; w[5] = mb[5]; w[6] = mb[6]; w[7] = mb[7];
+    // bytes 32..35 = LE index -> big-endian word w[8]
+    w[8] = (uint32_t(index & 0xffU) << 24) |
+           (uint32_t((index >> 8) & 0xffU) << 16) |
+           (uint32_t((index >> 16) & 0xffU) << 8) |
+           uint32_t((index >> 24) & 0xffU);
+    w[9] = 0x80000000U;     // byte 36 = 0x80
+    w[10] = 0U; w[11] = 0U; w[12] = 0U; w[13] = 0U; w[14] = 0U;
+    w[15] = 36U * 8U;       // message bit length
+
+    uint32_t a = mb[8], b = mb[9], c = mb[10], d = mb[11];
+    uint32_t e = mb[12], f = mb[13], g = mb[14], h = mb[15];
+    #pragma unroll
+    for (uint32_t t = 8; t < 64; ++t) {
+        uint32_t wt;
+        if (t < 16) {
+            wt = w[t];
+        } else {
+            wt = d_ms_sig1(w[(t - 2) & 15U]) + w[(t - 7) & 15U] +
+                 d_ms_sig0(w[(t - 15) & 15U]) + w[(t - 16) & 15U];
+            w[t & 15U] = wt;
+        }
+        const uint32_t t1 = h + d_ms_ep1(e) + d_ms_ch(e, f, g) + d_K[t] + wt;
+        const uint32_t t2 = d_ms_ep0(a) + d_ms_maj(a, b, c);
+        h = g; g = f; f = e; e = d + t1;
+        d = c; c = b; b = a; a = t1 + t2;
+    }
+    // Final state[0] = H0_init + a; candidate is its little-endian first 4 bytes.
+    return d_ms_bswap32(0x6a09e667U + a) & MODULUS;
+}
+
+// from_oracle using a precomputed midstate, with byte-exact fallback to the
+// original full-schedule path for the (rare) retry / rejection cases.
+__device__ __forceinline__ Element d_from_oracle_ms(const uint32_t* midstate,
+                                                    const uint8_t* seed,
+                                                    uint32_t index)
+{
+    const uint32_t candidate = d_candidate_from_midstate_local(midstate, index);
+    if (candidate < MODULUS) {
+        return candidate;
+    }
+    return d_from_oracle(seed, index);  // retry>0 + fallback handled identically
+}
+
+// Precompute kernel (the "2-kernel scalar" form): one thread per seed writes the
+// 16-word midstate into a workspace buffer; the gen kernels then load those 16
+// words as scalars/registers and resume at round 8. Seeds may be strided in the
+// source (the 4 noise seeds per nonce are interleaved), so seed i is read at
+// (seed_base + i*seed_stride_bytes) and written COMPACT at midstates[i*16].
+__global__ void ComputeSeedMidstatesKernel(const uint8_t* seed_base,
+                                           uint32_t seed_stride_bytes,
+                                           uint32_t seed_count,
+                                           uint32_t* midstates)
+{
+    const uint32_t idx = blockIdx.x * blockDim.x + threadIdx.x;
+    if (idx >= seed_count) {
+        return;
+    }
+    uint32_t ms[16];
+    d_seed_midstate(seed_base + size_t(idx) * seed_stride_bytes, ms);
+    uint32_t* out = midstates + size_t(idx) * 16;
+    #pragma unroll
+    for (int i = 0; i < 16; ++i) {
+        out[i] = ms[i];
+    }
+}
+
+namespace {
+// Cached per-call midstate scratch. The Generate* launches run sequentially on
+// the default stream, so a single grown-on-demand buffer is reused safely
+// across calls (avoids a cudaMalloc/cudaFree on every batch launch).
+uint32_t* g_midstate_scratch = nullptr;
+size_t g_midstate_scratch_seeds = 0;
+
+uint32_t* EnsureMidstateScratch(uint32_t seed_count)
+{
+    if (seed_count <= g_midstate_scratch_seeds && g_midstate_scratch != nullptr) {
+        return g_midstate_scratch;
+    }
+    if (g_midstate_scratch != nullptr) {
+        cudaFree(g_midstate_scratch);
+        g_midstate_scratch = nullptr;
+        g_midstate_scratch_seeds = 0;
+    }
+    if (cudaMalloc(&g_midstate_scratch, size_t(seed_count) * 16 * sizeof(uint32_t)) != cudaSuccess) {
+        g_midstate_scratch = nullptr;
+        g_midstate_scratch_seeds = 0;
+        return nullptr;
+    }
+    g_midstate_scratch_seeds = seed_count;
+    return g_midstate_scratch;
+}
